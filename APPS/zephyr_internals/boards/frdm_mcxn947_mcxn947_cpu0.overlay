#include <freq.h>

/ {
	aliases {
		ambient-temp0 = &p3t1755_sensor;
	};
};

&i3c1 {
	i2c-scl-hz = <DT_FREQ_K(400)>;
	i3c-scl-hz = <DT_FREQ_K(400)>;
	i3c-od-scl-hz = <DT_FREQ_K(100)>;

	p3t1755_sensor: p3t1755@4800000236152a0090 {
		compatible = "nxp,p3t1755";
		reg = <0x48 0x0236 0x152a0090>;
		status = "okay";
	};
};